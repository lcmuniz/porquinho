# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_DB_URL=jdbc:postgresql://db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=your-db-password

# Frontend
VITE_API_BASE_URL=http://localhost/api

# -------------------------------------------------------
# GitHub Secrets (configure in GitHub repo Settings > Secrets)
# These are NOT used locally, only in CI/CD workflows.
# -------------------------------------------------------
# VPS_HOST=your-vps-ip-or-domain
# VPS_USER=your-ssh-username
# VPS_SSH_KEY=your-private-ssh-key
