# ==============================================
# Connection Pooling (TRANSACTION MODE)
# ==============================================
# Formato geral:
# jdbc:postgresql://[POOLER_HOST]:[POOLER_PORT]/postgres?user=[USER]&password=[PASSWORD]
#
# Onde:
#   POOLER_HOST: aws-0-[região].pooler.supabase.com (exemplo: aws-0-us-east-1)
#   POOLER_PORT: 6543 (pooling usa porta 6543, não 5432)
#   USER: postgres.[seu-projeto-id]
#   PASSWORD: sua senha do banco

# Exemplo (substitua [região] pela região correta):
SUPABASE_DB_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres?user=postgres.vhkjyefwpwtlcyuznqgq&password=facial-slurp-jockey

# OU se preferir separado:
SUPABASE_DB_USERNAME=postgres.vhkjyefwpwtlcyuznqgq
SUPABASE_DB_PASSWORD=facial-slurp-jockey

# JWT permanece o mesmo:
SUPABASE_JWT_ISSUER_URI=https://vhkjyefwpwtlcyuznqgq.supabase.co/auth/v1
SUPABASE_JWT_JWK_SET_URI=https://vhkjyefwpwtlcyuznqgq.supabase.co/auth/v1/jwks

# Redis (opcional):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend (docker-compose):
VITE_API_BASE_URL=http://localhost/api

# ==============================================
# NOTAS:
# ==============================================
# 1. Connection Pooling é mais estável que direct connection
# 2. Usa porta 6543 em vez de 5432
# 3. Username inclui o projeto ID: postgres.[projeto-id]
# 4. Funciona mesmo se o projeto ficar pausado e retornar
